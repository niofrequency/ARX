*.safetensors
*.ckpt
*.pt
*.bin
*.onnx
models/
pulid/

# =========================================
# Environment Variables & Secrets
# =========================================
.env
.env.*
!.env.example

# =========================================
# OS & Editor Files
# =========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
