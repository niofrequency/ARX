# =========================================
# Node.js & React (Vite)
# =========================================
node_modules/
dist/
dist-ssr/
*.local

# npm/yarn/pnpm diagnostic logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================================
# Python & AI Models
# =========================================
